# API 运行模式：
# local  = 本地开发，前端走 Vite /devproxy
# domain = 国内域名代理，前端请求 VITE_API_BASE_URL
# tunnel = Cloudflare Pages 等国外域名，前端走 /devproxy，再由 Pages Function 转发到本机代理
# direct = 直接请求 UNIRUN API，仅用于接口调试；普通浏览器使用可能被 CORS/WAF 拦截
VITE_API_MODE=local

# UNIRUN 官方接口地址，用于 local/direct 模式
VITE_UNIRUN_API_BASE=https://run-lb.tanmasports.com/v1

# 国内域名代理地址，用于 domain 模式
# Example: https://api.example.com
VITE_API_BASE_URL=

# 本机代理或 Cloudflare Tunnel 地址，用于 tunnel 模式；Cloudflare Pages 部署时通常保持 /devproxy
VITE_TUNNEL_API_BASE=/devproxy

# 可选：当 domain/worker 代理启用 PROXY_TOKEN 时设置。
# 注意：前端变量会进入浏览器包，不能当作真正私密的服务端密钥。
VITE_PROXY_TOKEN=

# 自部署定时任务接口【可选】
# Example: https://api.autorun.yourdomain.com
VITE_AUTORUN_SERVER_BASE=
