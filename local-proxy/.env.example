PORT=18923
UNIRUN_TARGET=https://run-lb.tanmasports.com/v1

# 推荐在 Cloudflare Tunnel 暴露本机代理时启用。
# Pages Function 侧设置同值 LOCAL_PROXY_TOKEN，浏览器不会直接拿到这个值。
PROXY_TOKEN=

# 可选：限制允许读取代理响应的前端来源，多个用英文逗号分隔。
# Example: https://freerun.example.com,https://your-pages.pages.dev
ORIGIN_ALLOWLIST=

# 请求体上限，防止公网代理被大包占满内存。
REQUEST_BODY_LIMIT=10mb
